# =============================================================================
# Industrial Surface Defect Detection Platform - Environment Variables
# =============================================================================
# Copy this file to .env and update values for your environment.

# --- Database ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/defect_detection
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=defect_detection
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000

# --- Frontend ---
STREAMLIT_PORT=8501
API_BASE_URL=http://localhost:8000

# --- MLflow ---
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=defect-detection

# --- Model ---
MODEL_WEIGHTS_DIR=./models
DEVICE=auto

# --- Logging ---
LOG_LEVEL=INFO
